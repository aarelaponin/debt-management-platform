<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="rptTaxDebtStatus" language="java" pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    <style name="Bold" fontName="SansSerif" fontSize="10">
        <conditionalStyle>
            <conditionExpression><![CDATA["TOTAL".equals($F{line_type})]]></conditionExpression>
            <style isBold="true" backcolor="#EEEEEE" mode="Opaque"><box><topPen lineWidth="0.5"/></box></style>
        </conditionalStyle>
    </style>
    <queryString>
        <![CDATA[
        SELECT category, line_type, cases, total_debt, avg_debt, sortkey FROM (
          SELECT COALESCE(NULLIF(d.c_debtcategory,''), c.c_category, '-') AS category, 'DETAIL' AS line_type,
                 COUNT(*)::int AS cases,
                 COALESCE(SUM(COALESCE(NULLIF(d.c_consolidatedamount,'')::numeric,0)),0) AS total_debt,
                 ROUND(AVG(COALESCE(NULLIF(d.c_consolidatedamount,'')::numeric,0)),2) AS avg_debt, 1 AS sortkey
          FROM app_fd_cmcase c JOIN app_fd_dmdebt d ON d.id=c.id
          WHERE c.c_casetype='DM' AND COALESCE(d.c_writeoffstatus,'')<>'written-off'
            AND COALESCE(c.c_currentstate,'') NOT IN (SELECT s.c_code FROM app_fd_mmstate s WHERE s.c_isterminal='true')
          GROUP BY 1
          UNION ALL
          SELECT 'TOTAL','TOTAL', COUNT(*)::int,
                 COALESCE(SUM(COALESCE(NULLIF(d.c_consolidatedamount,'')::numeric,0)),0),
                 ROUND(AVG(COALESCE(NULLIF(d.c_consolidatedamount,'')::numeric,0)),2), 9
          FROM app_fd_cmcase c JOIN app_fd_dmdebt d ON d.id=c.id
          WHERE c.c_casetype='DM' AND COALESCE(d.c_writeoffstatus,'')<>'written-off'
            AND COALESCE(c.c_currentstate,'') NOT IN (SELECT s.c_code FROM app_fd_mmstate s WHERE s.c_isterminal='true')
        ) q ORDER BY sortkey, category
        ]]>
    </queryString>
    <field name="category" class="java.lang.String"/>
    <field name="line_type" class="java.lang.String"/>
    <field name="cases" class="java.lang.Integer"/>
    <field name="total_debt" class="java.math.BigDecimal"/>
    <field name="avg_debt" class="java.math.BigDecimal"/>
    <title>
        <band height="58">
            <staticText><reportElement x="0" y="0" width="555" height="24"/>
                <textElement><font fontName="SansSerif" size="16" isBold="true"/></textElement>
                <text><![CDATA[MTCA — Tax Debt Status Report]]></text></staticText>
            <staticText><reportElement x="0" y="26" width="400" height="14"/>
                <textElement><font fontName="SansSerif" size="10"/></textElement>
                <text><![CDATA[Outstanding debt by category (RPT-FR-014)]]></text></staticText>
            <textField pattern="dd MMM yyyy HH:mm"><reportElement x="355" y="26" width="200" height="14"/>
                <textElement textAlignment="Right"><font fontName="SansSerif" size="10"/></textElement>
                <textFieldExpression class="java.util.Date"><![CDATA[new java.util.Date()]]></textFieldExpression></textField>
        </band>
    </title>
    <columnHeader>
        <band height="20">
            <staticText><reportElement x="0" y="0" width="155" height="18"/><textElement verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement><text><![CDATA[Category]]></text></staticText>
            <staticText><reportElement x="155" y="0" width="90" height="18"/><textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement><text><![CDATA[Cases]]></text></staticText>
            <staticText><reportElement x="245" y="0" width="160" height="18"/><textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement><text><![CDATA[Total debt (EUR)]]></text></staticText>
            <staticText><reportElement x="405" y="0" width="150" height="18"/><textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement><text><![CDATA[Avg debt (EUR)]]></text></staticText>
            <line><reportElement x="0" y="18" width="555" height="1"/></line>
        </band>
    </columnHeader>
    <detail>
        <band height="18">
            <textField><reportElement style="Bold" x="0" y="0" width="155" height="16"/><textElement verticalAlignment="Middle"/><textFieldExpression class="java.lang.String"><![CDATA[$F{category}]]></textFieldExpression></textField>
            <textField><reportElement style="Bold" x="155" y="0" width="90" height="16"/><textElement textAlignment="Right" verticalAlignment="Middle"/><textFieldExpression class="java.lang.Integer"><![CDATA[$F{cases}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement style="Bold" x="245" y="0" width="160" height="16"/><textElement textAlignment="Right" verticalAlignment="Middle"/><textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{total_debt}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement style="Bold" x="405" y="0" width="150" height="16"/><textElement textAlignment="Right" verticalAlignment="Middle"/><textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{avg_debt}]]></textFieldExpression></textField>
        </band>
    </detail>
    <pageFooter>
        <band height="16"><textField><reportElement x="355" y="0" width="200" height="14"/><textElement textAlignment="Right"><font fontName="SansSerif" size="8"/></textElement><textFieldExpression class="java.lang.String"><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression></textField></band>
    </pageFooter>
</jasperReport>
