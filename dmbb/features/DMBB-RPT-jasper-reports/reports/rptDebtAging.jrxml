<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="rptDebtAging" language="java" pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    <style name="Detail" fontName="SansSerif" fontSize="10"/>
    <style name="Bold" fontName="SansSerif" fontSize="10" isBold="true">
        <conditionalStyle>
            <conditionExpression><![CDATA["TOTAL".equals($F{line_type})]]></conditionExpression>
            <style isBold="true" backcolor="#EEEEEE" mode="Opaque">
                <box><topPen lineWidth="0.5"/></box>
            </style>
        </conditionalStyle>
    </style>
    <queryString>
        <![CDATA[
        WITH debts AS (
          SELECT COALESCE(NULLIF(d.c_consolidatedamount,'')::numeric,0) AS amt,
                 EXTRACT(day FROM now() - c.datecreated) AS age
          FROM app_fd_cmcase c JOIN app_fd_dmdebt d ON d.id = c.id
          WHERE c.c_casetype = 'DM'
            AND COALESCE(d.c_writeoffstatus,'') <> 'written-off'
            AND COALESCE(c.c_currentstate,'') NOT IN
                (SELECT s.c_code FROM app_fd_mmstate s WHERE s.c_isterminal='true')
        ),
        banded AS (
          SELECT amt,
            CASE WHEN age<=30 THEN '0-30 days' WHEN age<=60 THEN '31-60 days'
                 WHEN age<=90 THEN '61-90 days' WHEN age<=180 THEN '91-180 days'
                 WHEN age<=365 THEN '181-365 days' ELSE 'over 365 days' END AS band,
            CASE WHEN age<=30 THEN 1 WHEN age<=60 THEN 2 WHEN age<=90 THEN 3
                 WHEN age<=180 THEN 4 WHEN age<=365 THEN 5 ELSE 6 END AS sortkey
          FROM debts
        )
        SELECT band AS age_band, 'DETAIL' AS line_type, COUNT(*)::int AS cases,
               COALESCE(SUM(amt),0) AS total_debt, sortkey
        FROM banded GROUP BY band, sortkey
        UNION ALL
        SELECT 'TOTAL', 'TOTAL', COUNT(*)::int, COALESCE(SUM(amt),0), 99 FROM banded
        ORDER BY sortkey
        ]]>
    </queryString>
    <field name="age_band" class="java.lang.String"/>
    <field name="line_type" class="java.lang.String"/>
    <field name="cases" class="java.lang.Integer"/>
    <field name="total_debt" class="java.math.BigDecimal"/>
    <title>
        <band height="58">
            <staticText>
                <reportElement x="0" y="0" width="555" height="24"/>
                <textElement><font fontName="SansSerif" size="16" isBold="true"/></textElement>
                <text><![CDATA[MTCA — Debt Aging Report]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="26" width="400" height="14"/>
                <textElement><font fontName="SansSerif" size="10"/></textElement>
                <text><![CDATA[Outstanding tax debt by age band (RPT-FR-001/008)]]></text>
            </staticText>
            <textField pattern="dd MMM yyyy HH:mm">
                <reportElement x="355" y="26" width="200" height="14"/>
                <textElement textAlignment="Right"><font fontName="SansSerif" size="10"/></textElement>
                <textFieldExpression class="java.util.Date"><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
        </band>
    </title>
    <columnHeader>
        <band height="20">
            <staticText>
                <reportElement x="0" y="0" width="255" height="18"/>
                <textElement verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Age band]]></text>
            </staticText>
            <staticText>
                <reportElement x="255" y="0" width="100" height="18"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Cases]]></text>
            </staticText>
            <staticText>
                <reportElement x="355" y="0" width="200" height="18"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="SansSerif" size="10" isBold="true"/></textElement>
                <text><![CDATA[Total debt (EUR)]]></text>
            </staticText>
            <line><reportElement x="0" y="18" width="555" height="1"/></line>
        </band>
    </columnHeader>
    <detail>
        <band height="18">
            <textField>
                <reportElement style="Bold" x="0" y="0" width="255" height="16"/>
                <textElement verticalAlignment="Middle"/>
                <textFieldExpression class="java.lang.String"><![CDATA[$F{age_band}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement style="Bold" x="255" y="0" width="100" height="16"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"/>
                <textFieldExpression class="java.lang.Integer"><![CDATA[$F{cases}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement style="Bold" x="355" y="0" width="200" height="16"/>
                <textElement textAlignment="Right" verticalAlignment="Middle"/>
                <textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{total_debt}]]></textFieldExpression>
            </textField>
        </band>
    </detail>
    <pageFooter>
        <band height="16">
            <textField>
                <reportElement x="355" y="0" width="200" height="14"/>
                <textElement textAlignment="Right"><font fontName="SansSerif" size="8"/></textElement>
                <textFieldExpression class="java.lang.String"><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>
</jasperReport>
