<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="rptDebtorsList" language="java" pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    <style name="Bold" fontName="SansSerif" fontSize="9">
        <conditionalStyle>
            <conditionExpression><![CDATA["TOTAL".equals($F{line_type})]]></conditionExpression>
            <style isBold="true" backcolor="#EEEEEE" mode="Opaque"><box><topPen lineWidth="0.5"/></box></style>
        </conditionalStyle>
    </style>
    <queryString>
        <![CDATA[
        WITH dlist AS (
          SELECT c.c_tin AS tin, COALESCE(NULLIF(c.c_taxpayername,''), c.c_tin) AS taxpayer,
                 COALESCE(NULLIF(d.c_consolidatedamount,'')::numeric,0) AS total_debt,
                 GREATEST(0, EXTRACT(day FROM now()-c.datecreated))::int AS debt_age_days,
                 COALESCE(NULLIF(d.c_debtcategory,''), c.c_category, '-') AS category,
                 COALESCE(NULLIF(d.c_stage,''),'-') AS stage
          FROM app_fd_cmcase c JOIN app_fd_dmdebt d ON d.id=c.id
          WHERE c.c_casetype='DM' AND COALESCE(d.c_writeoffstatus,'')<>'written-off'
            AND COALESCE(c.c_currentstate,'') NOT IN (SELECT s.c_code FROM app_fd_mmstate s WHERE s.c_isterminal='true')
        )
        SELECT tin, taxpayer, total_debt, debt_age_days, category, stage, 'DETAIL' AS line_type, 1 AS sortkey FROM dlist
        UNION ALL
        SELECT 'TOTAL ('||COUNT(*)||' debtors)', '', COALESCE(SUM(total_debt),0), 0, '', '', 'TOTAL', 9 FROM dlist
        ORDER BY sortkey, total_debt DESC
        ]]>
    </queryString>
    <field name="tin" class="java.lang.String"/>
    <field name="taxpayer" class="java.lang.String"/>
    <field name="total_debt" class="java.math.BigDecimal"/>
    <field name="debt_age_days" class="java.lang.Integer"/>
    <field name="category" class="java.lang.String"/>
    <field name="stage" class="java.lang.String"/>
    <field name="line_type" class="java.lang.String"/>
    <title>
        <band height="58">
            <staticText><reportElement x="0" y="0" width="555" height="24"/><textElement><font fontName="SansSerif" size="16" isBold="true"/></textElement><text><![CDATA[MTCA — Debtors List Report]]></text></staticText>
            <staticText><reportElement x="0" y="26" width="400" height="14"/><textElement><font fontName="SansSerif" size="10"/></textElement><text><![CDATA[Taxpayers with outstanding debt (RPT-FR-002)]]></text></staticText>
            <textField pattern="dd MMM yyyy HH:mm"><reportElement x="355" y="26" width="200" height="14"/><textElement textAlignment="Right"><font fontName="SansSerif" size="10"/></textElement><textFieldExpression class="java.util.Date"><![CDATA[new java.util.Date()]]></textFieldExpression></textField>
        </band>
    </title>
    <columnHeader>
        <band height="20">
            <staticText><reportElement x="0" y="0" width="90" height="18"/><textElement verticalAlignment="Middle"><font fontName="SansSerif" size="9" isBold="true"/></textElement><text><![CDATA[TIN]]></text></staticText>
            <staticText><reportElement x="90" y="0" width="170" height="18"/><textElement verticalAlignment="Middle"><font fontName="SansSerif" size="9" isBold="true"/></textElement><text><![CDATA[Taxpayer]]></text></staticText>
            <staticText><reportElement x="260" y="0" width="95" height="18"/><textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="SansSerif" size="9" isBold="true"/></textElement><text><![CDATA[Total debt]]></text></staticText>
            <staticText><reportElement x="355" y="0" width="55" height="18"/><textElement textAlignment="Right" verticalAlignment="Middle"><font fontName="SansSerif" size="9" isBold="true"/></textElement><text><![CDATA[Age (d)]]></text></staticText>
            <staticText><reportElement x="410" y="0" width="60" height="18"/><textElement verticalAlignment="Middle"><font fontName="SansSerif" size="9" isBold="true"/></textElement><text><![CDATA[Cat.]]></text></staticText>
            <staticText><reportElement x="470" y="0" width="85" height="18"/><textElement verticalAlignment="Middle"><font fontName="SansSerif" size="9" isBold="true"/></textElement><text><![CDATA[Stage]]></text></staticText>
            <line><reportElement x="0" y="18" width="555" height="1"/></line>
        </band>
    </columnHeader>
    <detail>
        <band height="15">
            <textField><reportElement style="Bold" x="0" y="0" width="90" height="14"/><textElement verticalAlignment="Middle"/><textFieldExpression class="java.lang.String"><![CDATA[$F{tin}]]></textFieldExpression></textField>
            <textField><reportElement style="Bold" x="90" y="0" width="170" height="14"/><textElement verticalAlignment="Middle"/><textFieldExpression class="java.lang.String"><![CDATA[$F{taxpayer}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement style="Bold" x="260" y="0" width="95" height="14"/><textElement textAlignment="Right" verticalAlignment="Middle"/><textFieldExpression class="java.math.BigDecimal"><![CDATA[$F{total_debt}]]></textFieldExpression></textField>
            <textField><reportElement style="Bold" x="355" y="0" width="55" height="14"/><textElement textAlignment="Right" verticalAlignment="Middle"/><textFieldExpression class="java.lang.Integer"><![CDATA[$F{debt_age_days}]]></textFieldExpression></textField>
            <textField><reportElement style="Bold" x="410" y="0" width="60" height="14"/><textElement verticalAlignment="Middle"/><textFieldExpression class="java.lang.String"><![CDATA[$F{category}]]></textFieldExpression></textField>
            <textField><reportElement style="Bold" x="470" y="0" width="85" height="14"/><textElement verticalAlignment="Middle"/><textFieldExpression class="java.lang.String"><![CDATA[$F{stage}]]></textFieldExpression></textField>
        </band>
    </detail>
    <pageFooter>
        <band height="16"><textField><reportElement x="355" y="0" width="200" height="14"/><textElement textAlignment="Right"><font fontName="SansSerif" size="8"/></textElement><textFieldExpression class="java.lang.String"><![CDATA["Page " + $V{PAGE_NUMBER}]]></textFieldExpression></textField></band>
    </pageFooter>
</jasperReport>
